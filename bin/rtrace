#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    TARGET="$(readlink "$SOURCE")"
    if [[ "$TARGET" != /* ]]; then
        SOURCE="$DIR/$TARGET"
    else
        SOURCE="$TARGET"
    fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="${RTRACE_REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

usage() {
    cat <<'EOF'
Usage:
    rtrace codex [--strace|--no-strace] [exec] [prompt...]

Examples:
  rtrace codex
  rtrace codex "scan this repo and summarize"
  rtrace codex exec "count shell scripts and print result"

Notes:
  - This command wraps run_intercepted_codex.sh.
    - Low-level capture is eBPF-based (prototype); flags are kept for compatibility.
  - For transparent interception, root privileges may be required.
EOF
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

SUBCOMMAND="$1"
shift

case "$SUBCOMMAND" in
    codex)
        RUNNER="$REPO_ROOT/run_intercepted_codex.sh"
        if [[ ! -x "$RUNNER" ]]; then
            echo "Error: $RUNNER not found or not executable." >&2
            exit 1
        fi

        USE_STRACE=true
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --no-strace)
                    USE_STRACE=false
                    shift
                    ;;
                --strace)
                    USE_STRACE=true
                    shift
                    ;;
                *)
                    break
                    ;;
            esac
        done

        ARGS=()
        if ! $USE_STRACE; then
            ARGS+=(--no-strace)
        fi

        if [[ $# -eq 0 ]]; then
            :
        elif [[ "$1" == "exec" ]]; then
            shift
            if [[ $# -eq 0 ]]; then
                echo "Error: 'exec' requires a prompt." >&2
                exit 1
            fi
            ARGS+=(exec "$*")
        else
            ARGS+=("$*")
        fi

        if [[ "${EUID}" -ne 0 ]]; then
            exec sudo "$RUNNER" "${ARGS[@]}"
        fi
        exec "$RUNNER" "${ARGS[@]}"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "Unknown subcommand: $SUBCOMMAND" >&2
        usage
        exit 1
        ;;
esac
