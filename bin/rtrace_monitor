#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    TARGET="$(readlink "$SOURCE")"
    if [[ "$TARGET" != /* ]]; then
        SOURCE="$DIR/$TARGET"
    else
        SOURCE="$TARGET"
    fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="${RTRACE_REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
VENV_PATH="${RTRACE_VENV:-$REPO_ROOT/.venv}"

if [[ -f "/.dockerenv" ]]; then
    HOST="0.0.0.0"
else
    HOST="127.0.0.1"
fi
PORT="8099"
OBS_ROOT="${AGENT_OBS_ROOT:-$REPO_ROOT/obs}"

usage() {
    cat <<'EOF'
Usage: rtrace_monitor [--host <host>] [--port <port>] [--obs-root <path>]

Starts the observability dashboard server.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --host)
            HOST="$2"
            shift 2
            ;;
        --port)
            PORT="$2"
            shift 2
            ;;
        --obs-root)
            OBS_ROOT="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage
            exit 1
            ;;
    esac
done

PYTHON_BIN="$VENV_PATH/bin/python"
if [[ ! -x "$PYTHON_BIN" ]]; then
    echo "Error: $PYTHON_BIN not found. Run scripts/install_rtrace.sh first." >&2
    exit 1
fi

export AGENT_OBS_ROOT="$OBS_ROOT"
export OBS_TRACE_DIR="$OBS_ROOT/traces"
export OBS_EVENTS_DIR="$OBS_ROOT/events"

mkdir -p "$OBS_ROOT/traces" "$OBS_ROOT/events" "$OBS_ROOT/mitm"

exec "$PYTHON_BIN" -m uvicorn observability_dashboard.app:app --host "$HOST" --port "$PORT"
