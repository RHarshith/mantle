#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    TARGET="$(readlink "$SOURCE")"
    if [[ "$TARGET" != /* ]]; then
        SOURCE="$DIR/$TARGET"
    else
        SOURCE="$TARGET"
    fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="${RTRACE_REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
SCENARIOS_DIR="$REPO_ROOT/trace_scenarios"
RUNNER="$REPO_ROOT/run_intercepted_codex.sh"

usage() {
    cat <<'EOF'
Usage:
    rtrace_test --list
    rtrace_test <suite_name> [--no-cleanup] [--no-setup] [--mode <proxy|transparent>] [--trace-id <id>] [--dry-run]

Examples:
    rtrace_test sys_admin_test
    rtrace_test sys_admin_test --no-cleanup
    rtrace_test --list
EOF
}

list_suites() {
    find "$SCENARIOS_DIR" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

NO_SETUP=false
NO_CLEANUP=false
DRY_RUN=false
MODE="${RTRACE_INTERCEPT_MODE:-proxy}"
TRACE_ID=""
SUITE_NAME=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --list)
            list_suites
            exit 0
            ;;
        --no-setup)
            NO_SETUP=true
            shift
            ;;
        --no-cleanup)
            NO_CLEANUP=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --mode)
            MODE="$2"
            shift 2
            ;;
        --trace-id)
            TRACE_ID="$2"
            shift 2
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage
            exit 1
            ;;
        *)
            if [[ -n "$SUITE_NAME" ]]; then
                echo "Only one suite name is allowed" >&2
                exit 1
            fi
            SUITE_NAME="$1"
            shift
            ;;
    esac
done

if [[ -z "$SUITE_NAME" ]]; then
    echo "Suite name is required." >&2
    usage
    exit 1
fi

SUITE_DIR="$SCENARIOS_DIR/$SUITE_NAME"
PROMPT_FILE="$SUITE_DIR/prompt.txt"
SETUP_SCRIPT="$SUITE_DIR/setup.sh"
VERIFY_SCRIPT="$SUITE_DIR/verify.sh"
CLEANUP_SCRIPT="$SUITE_DIR/cleanup.sh"

for required in "$SUITE_DIR" "$PROMPT_FILE" "$SETUP_SCRIPT" "$VERIFY_SCRIPT" "$CLEANUP_SCRIPT"; do
    if [[ ! -e "$required" ]]; then
        echo "Missing required suite artifact: $required" >&2
        exit 1
    fi
done

chmod +x "$SETUP_SCRIPT" "$VERIFY_SCRIPT" "$CLEANUP_SCRIPT"

if [[ ! -x "$RUNNER" ]]; then
    echo "Runner not found or not executable: $RUNNER" >&2
    exit 1
fi

if [[ ! "$MODE" =~ ^(proxy|transparent)$ ]]; then
    echo "Invalid mode '$MODE'. Use proxy or transparent." >&2
    exit 1
fi

PROMPT_CONTENT="$(cat "$PROMPT_FILE")"

echo "[rtrace_test] Suite: $SUITE_NAME"
echo "[rtrace_test] Mode: $MODE"

ARGS=(--mode "$MODE")
if [[ -n "$TRACE_ID" ]]; then
    ARGS+=(--trace-id "$TRACE_ID")
fi
ARGS+=(exec "$PROMPT_CONTENT")

if $DRY_RUN; then
    echo "[rtrace_test] Dry run only. No setup/verify/cleanup executed."
    echo "[rtrace_test] Would run: $RUNNER ${ARGS[*]}"
    exit 0
fi

if ! $NO_SETUP; then
    echo "[rtrace_test] Running setup..."
    "$SETUP_SCRIPT"
fi

echo "[rtrace_test] Validating preconditions..."
"$VERIFY_SCRIPT"

cleanup() {
    if ! $NO_CLEANUP; then
        echo "[rtrace_test] Running cleanup..."
        "$CLEANUP_SCRIPT" || true
    fi
}

trap cleanup EXIT

echo "[rtrace_test] Running traced agent..."
"$RUNNER" "${ARGS[@]}"

echo "[rtrace_test] Post-run API /health status: $(curl -s -o /dev/null -w "%{http_code}" http://127.0.0.1:18080/health || echo fail)"
