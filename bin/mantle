#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    TARGET="$(readlink "$SOURCE")"
    if [[ "$TARGET" != /* ]]; then
        SOURCE="$DIR/$TARGET"
    else
        SOURCE="$TARGET"
    fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="${MANTLE_REPO_ROOT:-${RTRACE_REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}}"
VENV_PATH="${MANTLE_VENV:-${RTRACE_VENV:-$REPO_ROOT/.venv}}"

usage() {
    cat <<'EOF'
Usage:
  mantle serve [--host <host>] [--port <port>] [--obs-root <path>]
    mantle watch [--mode <proxy|transparent>] [--trace-id <id>] [--port <mitm_port>] [--interactive-ebpf] <executable> [args...]
    mantle cli [-i|--interactive] [--obs-root <path>] [<route>]

Commands:
    serve    Start the observability dashboard.
    watch    Run an executable under MITM + eBPF capture.
    cli      Explore traces from the terminal (interactive or URL-like mode).

Examples:
  mantle serve --host 0.0.0.0 --port 8099
  mantle watch codex
    mantle watch codex exec "inspect this repo and summarize"
    mantle watch --mode transparent codex --sandbox danger-full-access exec "trace network behavior"
  mantle watch aider "fix failing tests"
    mantle cli --interactive
    mantle cli trace_001.ebpf.jsonl/replay/turn_2/summary
EOF
}

cli_cmd() {
        local python_bin

        python_bin="$VENV_PATH/bin/python"
        if [[ ! -x "$python_bin" ]]; then
                echo "Error: $python_bin not found. Run scripts/install_mantle.sh first." >&2
                exit 1
        fi

        exec "$python_bin" -m mantle.cli.main "$@"
}

serve_cmd() {
    local host port obs_root python_bin
    local cli_obs_root repo_obs_root env_obs_root env_score repo_score

    if [[ -f "/.dockerenv" ]]; then
        host="0.0.0.0"
    else
        host="127.0.0.1"
    fi
    port="8099"
    cli_obs_root=""
    repo_obs_root="$REPO_ROOT/obs"
    env_obs_root="${AGENT_OBS_ROOT:-}"
    obs_root="$repo_obs_root"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --host)
                host="$2"
                shift 2
                ;;
            --port)
                port="$2"
                shift 2
                ;;
            --obs-root)
                cli_obs_root="$2"
                shift 2
                ;;
            -h|--help|help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown argument for 'serve': $1" >&2
                usage
                exit 1
                ;;
        esac
    done

    # --obs-root should always win. Otherwise, guard against stale AGENT_OBS_ROOT
    # values left behind after repository moves/renames.
    if [[ -n "$cli_obs_root" ]]; then
        obs_root="$cli_obs_root"
    elif [[ -n "$env_obs_root" ]]; then
        env_score=0
        repo_score=0
        if [[ -d "$env_obs_root/traces" ]]; then
            env_score=$((env_score + $(find "$env_obs_root/traces" -maxdepth 1 -type f -name '*.ebpf.jsonl' 2>/dev/null | wc -l)))
        fi
        if [[ -d "$env_obs_root/events" ]]; then
            env_score=$((env_score + $(find "$env_obs_root/events" -maxdepth 1 -type f -name '*.events.jsonl' 2>/dev/null | wc -l)))
        fi
        if [[ -d "$repo_obs_root/traces" ]]; then
            repo_score=$((repo_score + $(find "$repo_obs_root/traces" -maxdepth 1 -type f -name '*.ebpf.jsonl' 2>/dev/null | wc -l)))
        fi
        if [[ -d "$repo_obs_root/events" ]]; then
            repo_score=$((repo_score + $(find "$repo_obs_root/events" -maxdepth 1 -type f -name '*.events.jsonl' 2>/dev/null | wc -l)))
        fi

        if [[ "$env_score" -eq 0 && "$repo_score" -gt 0 ]]; then
            obs_root="$repo_obs_root"
            echo "[mantle] AGENT_OBS_ROOT has no logs; using repo obs root: $obs_root" >&2
        else
            obs_root="$env_obs_root"
        fi
    fi

    python_bin="$VENV_PATH/bin/python"
    if [[ ! -x "$python_bin" ]]; then
        echo "Error: $python_bin not found. Run scripts/install_mantle.sh first." >&2
        exit 1
    fi

    export AGENT_OBS_ROOT="$obs_root"
    export OBS_TRACE_DIR="$obs_root/traces"
    export OBS_EVENTS_DIR="$obs_root/events"

    mkdir -p "$obs_root/traces" "$obs_root/events" "$obs_root/mitm"

    exec "$python_bin" -m uvicorn mantle.dashboard.app:app --host "$host" --port "$port"
}

watch_cmd() {
    local runner executable resolved_executable preserve_env
    local -a runner_args passthrough task_args

    runner="$REPO_ROOT/run_intercepted_codex.sh"
    if [[ ! -x "$runner" ]]; then
        echo "Error: $runner not found or not executable." >&2
        exit 1
    fi

    passthrough=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode|--trace-id|--port)
                if [[ $# -lt 2 ]]; then
                    echo "Error: $1 requires a value." >&2
                    exit 1
                fi
                passthrough+=("$1" "$2")
                shift 2
                ;;
            --interactive-ebpf)
                passthrough+=("$1")
                shift
                ;;
            -h|--help|help)
                usage
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Unknown argument for 'watch': $1" >&2
                usage
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done

    if [[ $# -lt 1 ]]; then
        echo "Error: 'watch' requires an executable (for example: codex)." >&2
        usage
        exit 1
    fi

    executable="$1"
    shift

    # Resolve executables without requiring shell PATH/venv activation.
    if [[ "$executable" == */* ]]; then
        resolved_executable="$executable"
    elif [[ -x "$VENV_PATH/bin/$executable" ]]; then
        resolved_executable="$VENV_PATH/bin/$executable"
    elif command -v "$executable" >/dev/null 2>&1; then
        resolved_executable="$(command -v "$executable")"
    else
        resolved_executable="$executable"
    fi

    # Forward all arguments after <executable> exactly as provided.
    task_args=("$@")

    runner_args=("${passthrough[@]}" --agent "$resolved_executable")
    if [[ ${#task_args[@]} -gt 0 ]]; then
        runner_args+=(-- "${task_args[@]}")
    fi

    if [[ "${EUID}" -ne 0 ]]; then
        preserve_env="PATH,OPENAI_API_KEY,OAK1,OPENAI_BASE_URL,OPENAI_MODEL,AGENT_TRACE_ID,AGENT_OBS_ENABLED,AGENT_OBS_ROOT,RTRACE_VENV,RTRACE_INTERCEPT_MODE,RTRACE_FORCE_OPENAI_BASE,MANTLE_VENV,MANTLE_INTERCEPT_MODE,MANTLE_FORCE_OPENAI_BASE"
        exec sudo --preserve-env="$preserve_env" "$runner" "${runner_args[@]}"
    fi

    exec "$runner" "${runner_args[@]}"
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

case "$1" in
    serve)
        shift
        serve_cmd "$@"
        ;;
    watch)
        shift
        watch_cmd "$@"
        ;;
    cli)
        shift
        cli_cmd "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage
        exit 1
        ;;
esac
